# Hostinger / Apache config for SPA (served from repo root)
Options -MultiViews -Indexes
RewriteEngine On

# --- Block access to source / build / config files ----------------------
# These exist in the repo when deployed via Hostinger Git, but must NEVER
# be served over HTTP.
RedirectMatch 404 (?i)^/(\.git|\.github|\.workspace|\.vscode|\.idea|node_modules|src|public|scripts|dist|dist-static|tsconfig\.tsbuildinfo)(/|$)
RedirectMatch 404 (?i)^/(package\.json|package-lock\.json|bun\.lockb|bunfig\.toml|tsconfig.*\.json|vite\.config\.ts|wrangler\.jsonc|eslint\.config\.js|components\.json|\.prettierrc|\.prettierignore|\.gitignore|\.env.*|HOSTINGER_DEPLOY\.md|README\.md)$

# --- SPA routing --------------------------------------------------------
# Don't rewrite real files or directories
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Send everything else to index.html (client-side routing)
RewriteRule ^ index.html [L]

# --- Caching ------------------------------------------------------------
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|ttf|otf|eot|svg|png|jpe?g|gif|webp|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>

# --- Gzip ---------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# --- Force HTTPS (uncomment after enabling SSL on Hostinger) -----------
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
